generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PhotoStatus {
  pending
  approved
  rejected
}

model Member {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String?
  createdAt  DateTime @default(now())
  verifiedAt DateTime @default(now())
  displayName String?
  bio        String?

  // 关联到照片表
  photos     Photo[]

  @@index([createdAt])
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model Photo {
  id               String      @id @default(cuid())
  title            String
  description      String?
  url              String
  status           PhotoStatus @default(pending)
  createdAt        DateTime    @default(now())
  ownerMemberId    String      // 改为必填，会员上传照片时必须关联

  // 关联到会员表
  member           Member      @relation(fields: [ownerMemberId], references: [id])

  @@index([status, createdAt])
  @@index([ownerMemberId, createdAt])
}
