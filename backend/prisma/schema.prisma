generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["photo_member"]
}

model Member {
  id         String    @id @default(cuid())
  email      String    @unique
  createdAt  DateTime  @default(now())
  verifiedAt DateTime  @default(now())
  name       String?
  bio        String?
  password   String?
  photos     Photo[]
  userRole   UserRole?

  @@index([createdAt])
  @@schema("photo_member")
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@schema("photo_member")
}

model Photo {
  id            String      @id @default(cuid())
  title         String
  description   String?
  url           String
  status        PhotoStatus @default(pending)
  createdAt     DateTime    @default(now())
  ownerMemberId String
  member        Member      @relation(fields: [ownerMemberId], references: [id])

  @@index([status, createdAt])
  @@index([ownerMemberId, createdAt])
  @@schema("photo_member")
}

model Notice {
  id              String   @id @default(cuid())
  title           String
  createdAt       DateTime @default(now())
  createdMemberId String
  contentUrl      String

  @@index([createdAt])
  @@schema("photo_member")
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  userRoles UserRole[]

  @@schema("photo_member")
}

model UserRole {
  userId String @unique
  roleId Int
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roleId])
  @@schema("photo_member")
}

enum PhotoStatus {
  pending
  approved
  rejected

  @@schema("photo_member")
}
